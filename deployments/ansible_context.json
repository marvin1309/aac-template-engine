{
  "service": {
    "name": "aac-traefik",
    "stage": "dev",
    "image_repo": "traefik",
    "image_tag": 3.6,
    "description": "A modern HTTP reverse proxy and load balancer.",
    "icon": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/traefik.png",
    "category": "Traefik - Dashboards",
    "hostname": "aac-traefik",
    "friendly_name": "Traefik"
  },
  "config": {
    "domain_name": "int.fam-feser.de",
    "dashboard_enabled": true,
    "generate_hostname": true,
    "integrations": {
      "homepage": {
        "enabled": true
      },
      "autodns": {
        "enabled": true,
        "create_wildcard": true
      },
      "traefik": {
        "enabled": true,
        "cert_resolver": "ionos",
        "entrypoint": "websecure",
        "service_port": 8080
      }
    }
  },
  "environment": {
    "PUID": 1000,
    "PGID": 1000,
    "TZ": "Europe/Berlin",
    "HOMEPAGE_WIDGET_TYPE": "traefik",
    "HOMEPAGE_WIDGET_SLUG": "traefik-dashboard"
  },
  "secrets": {
    "LOG_LEVEL": "WARN",
    "IONOS_API_KEY": "fa20b7016ba74db3a6fb917af85b7f6f.VqY3HU2tv75uQjzpoRgVVCKyVauTZk8STkM_Jci56i3eBwmFWwj7HLcCnvpThbNY3dCjbFFd8v_pR1hGWyyk0g",
    "SOME_TEST_VAR": "test-value"
  },
  "dependencies": {},
  "volumes": {
    "docker_sock": {
      "type": "bind",
      "source": "/var/run/docker.sock"
    },
    "data": {
      "description": "F\u00c3\u00bcr Let's Encrypt Zertifikate und ACME"
    },
    "log": {
      "description": "Traefik Access- und App-Logs"
    },
    "config": {
      "description": "Statische und dynamische Konfigurationsdateien"
    },
    "letsencrypt": {
      "description": "Let's Encrypt Zertifikate"
    }
  },
  "network_definitions": {
    "secured": {
      "name": "services-secured",
      "external": true
    },
    "exposed": {
      "name": "services-exposed",
      "external": true
    },
    "interconnect": {
      "name": "docker-default",
      "external": true
    },
    "stack_internal": {
      "name": "aac-traefik_stack_internal",
      "driver": "bridge"
    }
  },
  "deployments": {
    "docker_compose": {
      "volumes": [
        "docker_sock:/var/run/docker.sock",
        "data:/data",
        "log:/log",
        "config:/etc/traefik",
        "letsencrypt:/letsencrypt"
      ],
      "networks_to_join": [],
      "command": [
        "--configFile=/etc/traefik/traefik.yml"
      ],
      "restart_policy": "always",
      "host_base_path": "/export/docker",
      "security_opts": [
        "no-new-privileges:true"
      ],
      "logging": {
        "driver": "json-file",
        "options": {
          "max-size": "10m",
          "max-file": "10"
        }
      }
    }
  },
  "stage": "dev",
  "ports": [
    {
      "name": "web",
      "port": 80,
      "external_port": 80,
      "protocol": "TCP"
    },
    {
      "name": "websecure",
      "port": 443,
      "external_port": 443,
      "protocol": "TCP"
    },
    {
      "name": "dashboard",
      "port": 8080,
      "external_port": 28080,
      "protocol": "TCP"
    }
  ],
  "deployment_enabled": true,
  "inventory_hostname_friendly": "Ci Validation Host",
  "processed_env": {
    "PUID": "1000",
    "PGID": "1000",
    "TZ": "Europe/Berlin",
    "HOMEPAGE_WIDGET_TYPE": "traefik",
    "HOMEPAGE_WIDGET_SLUG": "traefik-dashboard"
  },
  "processed_secrets": {
    "LOG_LEVEL": "WARN",
    "IONOS_API_KEY": "fa20b7016ba74db3a6fb917af85b7f6f.VqY3HU2tv75uQjzpoRgVVCKyVauTZk8STkM_Jci56i3eBwmFWwj7HLcCnvpThbNY3dCjbFFd8v_pR1hGWyyk0g",
    "SOME_TEST_VAR": "test-value"
  },
  "processed_networks": [
    "exposed",
    "interconnect",
    "secured",
    "stack_internal"
  ],
  "processed_labels": {
    "traefik.enable": "true",
    "traefik.http.routers.aac-traefik.rule": "Host(`dev.aac-traefik.ci-host.int.fam-feser.de`)",
    "traefik.http.routers.aac-traefik.entrypoints": "websecure",
    "traefik.http.routers.aac-traefik.tls": "true",
    "traefik.http.routers.aac-traefik.tls.certresolver": "ionos",
    "traefik.docker.network": "services-secured",
    "traefik.http.services.aac-traefik.loadbalancer.server.port": "8080",
    "auto-dns.createWildcard.aac-traefik": "true",
    "auto-dns.customDNS.aac-traefik": "false",
    "auto-dns.domain.aac-traefik": "int.fam-feser.de",
    "auto-dns.stage.aac-traefik": "dev",
    "auto-dns.service.aac-traefik": "aac-traefik",
    "auto-dns.hostname.aac-traefik": "ci-host",
    "homepage.group": "Traefik - Dashboards",
    "homepage.name": "Traefik - Ci Validation Host",
    "homepage.href": "https://dev.aac-traefik.ci-host.int.fam-feser.de",
    "homepage.icon": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/traefik.png",
    "homepage.description": "A modern HTTP reverse proxy and load balancer."
  },
  "processed_specs": {
    "security_opts": [
      "no-new-privileges:true"
    ],
    "logging": {
      "driver": "json-file",
      "options": {
        "max-size": "10m",
        "max-file": "10"
      }
    }
  },
  "processed_volumes": [
    "/var/run/docker.sock:/var/run/docker.sock",
    "/export/docker/aac-traefik/data:/data",
    "/export/docker/aac-traefik/log:/log",
    "/export/docker/aac-traefik/config:/etc/traefik",
    "/export/docker/aac-traefik/letsencrypt:/letsencrypt"
  ],
  "named_volumes": {},
  "ansible_directories": [
    {
      "path": "/export/docker/aac-traefik",
      "owner": "1000",
      "group": "1000"
    },
    {
      "path": "/var/run/docker.sock",
      "owner": "1000",
      "group": "1000"
    },
    {
      "path": "/export/docker/aac-traefik/data",
      "owner": "1000",
      "group": "1000"
    },
    {
      "path": "/export/docker/aac-traefik/log",
      "owner": "1000",
      "group": "1000"
    },
    {
      "path": "/export/docker/aac-traefik/config",
      "owner": "1000",
      "group": "1000"
    },
    {
      "path": "/export/docker/aac-traefik/letsencrypt",
      "owner": "1000",
      "group": "1000"
    }
  ]
}